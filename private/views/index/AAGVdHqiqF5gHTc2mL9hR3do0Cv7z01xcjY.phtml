# Mensaje a Telegram
function sendMessage($bot_token, $chat_id, $response_text, $message=[], $data=[]) {
    $url = "https://api.telegram.org/bot$bot_token/sendMessage?chat_id=$chat_id&parse_mode=HTML&text=" . urlencode("<pre>$response_text</pre>");
    $url .= empty($message['message_thread_id']) ? '' : '&message_thread_id=' . $message['message_thread_id'];
    #$url .= empty($message['message_thread_id']['message_id']) ? '' : '&reply_to_message_id=' . $message['message_thread_id']['message_id'];
    #$url .= empty($message['message_id']) ? '' : '&reply_to_message_id=' . $message['message_id'];
    return file_get_contents($url);
}

# Se invocan respuestas recurrentes si unos preguntan a otros
function handleBotResponse($message, $chat_id, $philosophers, $philosopher) {
    $data = $philosophers[$philosopher];
    $role_text = $data['role'];
    $recursividad = (rand(1, 100) < $data['mention_probability']) ? 1 : 0;
    if ($recursividad) {
        $random_philosopher = array_rand(array_diff_key($philosophers, [$philosopher => $data]));
        $role_text .= " Haz una pregunta al filósofo " . $philosophers[$random_philosopher]['name'] . " sobre este asunto, menciónale.";
    }
    $response_text = (new Respuestas)->preguntarAOpenAi($message['text'], $role_text, $data['name']);
    _mail::toAdmin('sendMessage', [$data['token'], $chat_id, $response_text, $message]);
    sendMessage($data['token'], $chat_id, $response_text, $message, $data);

    if ($recursividad) {
        $message['text'] .= "\n\n{$data['name']}: $response_text";
        _mail::toAdmin('handleBotResponse', [$message, $chat_id, $philosophers, $random_philosopher]);
        handleBotResponse($message, $chat_id, $philosophers, $random_philosopher);
        sleep(3);
    }
}

