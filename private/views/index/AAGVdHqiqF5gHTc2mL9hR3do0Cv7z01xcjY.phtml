# Crea o borra un Webhook
function setWebhook($bot_token, $bot, $action) {
    $webhook_url = "https://roleplus.app/index/AAGVdHqiqF5gHTc2mL9hR3do0Cv7z01xcjY/$bot";
    $url = "https://api.telegram.org/bot$bot_token/" . ($action === 'delete' ? 'deleteWebhook' : "setWebhook?url=$webhook_url");
