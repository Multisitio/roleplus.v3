<form data-autosave="salvar" enctype="multipart/form-data" method="post">
	<?php
	$apilador = function($ficha, $cajas, $personaje, $pid='') use (&$apilador) {
		foreach ($cajas as $i => $c) {
			if ($c->padre_idu != $pid && ($pid || $c->padre_idu)) continue;

			// Estilos base
			$s = '';
			if ($c->tipo != 'division' && $c->linea_nueva) $s .= 'clear:left;';
			
			$con_alto = !in_array($c->tipo, ['area_de_texto', 'retrato']);
			if ($con_alto && $c->alto) $s .= "height:$c->alto;overflow-y:auto;";

			if (in_array($c->tipo, ['campo_de_texto', 'casilla_y_texto', 'division']) && $c->margen) $s .= "margin:$c->margen !important;";
			if (in_array($c->tipo, ['campo_de_texto', 'casilla_y_texto']) && $c->sangria) $s .= "padding:$c->sangria !important;";
			
			if ($c->tipo == 'division' && $c->imagenes) {
				$s .= "background:url(/img/usuarios/$c->usuarios_idu/$c->imagenes) center no-repeat;background-size:cover;";
			}

			echo "<div class='s$c->tam_s m$c->tam_m l$c->tam_l xl$c->tam_xl' style='$s'>";

			match ($c->tipo) {
				'area_de_texto' => print "
					<label>$c->nombre</label>
					<textarea name='$c->variable_nombre' style='" . ($c->alto ? "height:$c->alto;overflow-y:auto" : '') . "'>{$personaje[$c->variable_nombre]}</textarea>",

				'campo' => print "
					<input type='text' " . ($c->borde ? '' : 'class="simple"') . " name='$c->variable_nombre' value='{$personaje[$c->variable_nombre]}'>",

				'campo_de_texto' => print "
					<label>$c->nombre</label>
					<input type='text' " . ($c->borde ? '' : 'class="simple"') . " name='$c->variable_nombre' placeholder='$c->variable_marcador' value='{$personaje[$c->variable_nombre]}'>
					<small>$c->notas</small>",

				'casilla_y_texto' => print "
					<label>
						<div class='display-cell'>
							<input type='checkbox' name='$c->variable_nombre'" . ( ! empty($personaje[$c->variable_nombre]) ? ' checked' : '') . "><span></span>
						</div>
						<div class='display-cell'>" . nl2br($c->texto, false) . "</div>
					</label>",

				'division' => (function() use ($c, $cajas, $i, $apilador, $ficha, $personaje) {
					$borde = $c->borde ? 'class="border border-'.rand(0,6).'"' : '';
					$style = $c->sangria ? "padding:$c->sangria !important;" : '';
					
					echo "<div $borde style='$style'>";
					unset($cajas[$i]);
					$apilador($ficha, $cajas, $personaje, $c->idu);
					echo "<div class='clear'></div></div>";
				})(),

				'imagen' => print "<img alt='" . t('Imagen') . "' src='/img/usuarios/$c->usuarios_idu/$c->imagenes'>",

				'linea_horizontal' => print "<hr style='margin:16px 0'>",

				'retrato' => (function() use ($c, $personaje) {
					$dropClass = $personaje[$c->variable_nombre] ? 'dropnocontent' : '';
					$borderClass = $c->borde ? 'border border-'.rand(0,6) : '';
					$style = $c->alto ? "height:$c->alto;overflow-y:auto" : '';
					
					echo "<label>$c->nombre</label>
					<div class='dropimage $dropClass $borderClass' style='$style'>
						<input type='file' name='imagenes[]'>
						<input type='hidden' name='fotos[]' value='$c->variable_nombre'>
						<input type='hidden' name='$c->variable_nombre' value='{$personaje[$c->variable_nombre]}'>";
					if ($personaje[$c->variable_nombre]) {
						echo "<img alt='" . t('Retrato') . "' src='/img/fichas/retratos/l.{$personaje[$c->variable_nombre]}'>";
					}
					echo "</div>";
				})(),

				'texto' => print "<label>$c->nombre</label>",

				'titulo' => print "<h$c->subtipo style='" . ($c->alineado ? "text-align:$c->alineado" : '') . "'>$c->nombre</h$c->subtipo>",

				default => null
			};
			echo "</div>";
		}
	};
	$apilador($ficha, $cajas, $personaje);
	?>

	<div class="fixed-bottom-right no-print scroll-down-hide">
		<?php if (Session::get('idu') == $ficha->usuarios_idu): ?>
			<a class="paper-btn btn-warning-outline mh5" href="/ev/fichas/cajas/<?=$ficha->idu?>">< <?=t('Diseñar')?></a>
		<?php endif; ?>

		<?php if ($personajes_usuarios && Session::get('idu') == $personajes_usuarios->usuarios_idu): ?>
			<button type="submit" class="paper-btn btn-danger-outline mh5" name="action" value="eliminar">- <?=t('Eliminar')?></button>
			<button type="submit" class="paper-btn btn-success-outline mh5" name="action" value="salvar">+ <?=t('Salvar')?></button>
		<?php endif; ?>

		<button type="submit" class="paper-btn btn-secondary-outline mh5" name="action" value="duplicar">+ <?=t('Duplicar')?></button>
		<a class="paper-btn btn-outline mh5" href="/ev/personajes/montados/<?=$ficha->idu?>">< <?=t('Personajes')?></a>
	</div>
	<input type="hidden" name="fichas_idu" value="<?=$ficha->idu?>">
	<input type="hidden" name="idu" value="<?=$idu?>">
</form>
