<?php
$idu = !empty($ele->elementos_idu) ? (string)$ele->elementos_idu : '';
$nombre = isset($ele->nombre) ? h($ele->nombre) : '';
$texto = isset($ele->texto) ? nl2br(h($ele->texto), false) : '';
$tipo = isset($ele->tipo) ? h($ele->tipo) : 'texto';
$usuarios_idu = isset($ele->usuarios_idu) ? (string)$ele->usuarios_idu : (string)Session::get('idu');
$posx = isset($ele->posicion_x) ? (int)$ele->posicion_x : 0;
$posy = isset($ele->posicion_y) ? (int)$ele->posicion_y : 0;
$fotos = isset($ele->fotos) ? (string)$ele->fotos : '';
$mp3 = isset($ele->mp3) ? (string)$ele->mp3 : '';
$youtube = isset($ele->youtube) ? (string)$ele->youtube : '';
$enviado = !empty($ele->enviado) ? 1 : 0;
$fondo = !empty($ele->fondo) ? 1 : 0;

/* ⮞ SSE: si el elemento ya no existe (borrado), emitir marcador de eliminación */
if (empty($ele) && !empty($eliminar)) {
	echo '<span data-remove_id="' . h((string)$eliminar) . '"></span>';
	return;
}

$foto_primaria = $fotos !== '' ? trim(preg_replace('/,.*/', '', $fotos)) : '';
$src_img_prev = $foto_primaria !== '' ? '/img/usuarios/' . $usuarios_idu . '/l.' . $foto_primaria : '';
$href_img_full = $foto_primaria !== '' ? '/img/usuarios/' . $usuarios_idu . '/' . $foto_primaria : '';

$edit_href = '/ev/elementos/editar_partida/' . $partida->idu . '/' . $idu;
$send_fondo = '/ev/panel/enviar_fondo/' . $partida->idu . '/' . $idu;
$send_visible = '/ev/panel/enviar_elemento/' . $partida->idu . '/' . $idu;
?>

<article
	data-id="<?= $idu ?>"
	data-draggable
	style="left: <?= (int)$posx ?>px; top: <?= (int)$posy ?>px;"
>
	<header>
		<!-- Lápiz dentro del header (4-draggable.css lo posiciona) -->
		<a
			data-ajax=".ajax.show"
			href="<?= $edit_href ?>"
			title="<?= t('Editar') ?>"
		>
			<img alt="<?= t('Editar') ?>" src="/img/icons/edit-2s.svg" width="20" height="20">
		</a>

		<h5><?= $nombre ?></h5>
	</header>

	<?php if ($src_img_prev !== ''): ?>
		<a href="<?= $href_img_full ?>" target="_blank" rel="noopener">
			<img alt="<?= t('Imagen de') ?> <?= $nombre ?>" src="<?= $src_img_prev ?>" loading="lazy">
		</a>
	<?php endif; ?>

	<section>
		<?php if ($texto !== ''): ?>
			<div><?= $texto ?></div>
		<?php endif; ?>

		<?php if ($mp3 !== ''): ?>
			<fieldset>
				<legend><?= h($mp3) ?></legend>
				<audio controls preload="none">
					<source type="audio/mpeg" src="/mp3/<?= h($mp3) ?>">
					<?= t('Audio no soportado.') ?>
				</audio>
			</fieldset>
		<?php endif; ?>

		<?php if ($youtube !== ''): ?>
			<div data-youtube="<?= h($youtube) ?>"></div>
		<?php endif; ?>
	</section>

	<hr>

	<footer>
		<?php if ($src_img_prev !== ''): ?>
			<label>
				<input
					type="radio"
					name="fondo"
					<?= $fondo ? 'checked' : '' ?>
					data-ajax="body"
					href="<?= $send_fondo ?>"
				>
				<?= t('Fijar de fondo') ?>
			</label>
		<?php endif; ?>

		<label>
			<input
				type="checkbox"
				<?= $enviado ? 'checked' : '' ?>
				data-ajax="body"
				href="<?= $send_visible ?>"
			>
			<?= t('Mostrar a jugadores') ?>
		</label>
	</footer>
</article>
