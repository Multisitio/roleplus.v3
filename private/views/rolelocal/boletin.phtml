/**
 * Sustituye en un bloque HTML todos los enlaces rotos por “[Enlace roto]”.
 *
 * @param string $html HTML de entrada.
 * @return string HTML con enlaces rotos reemplazados.
 */
function replaceBrokenLinks(string $html): string
{
    libxml_use_internal_errors(true);
    $dom = new DOMDocument();
    $dom->loadHTML($html, LIBXML_HTML_NOIMPLIED | LIBXML_HTML_NODEFDTD);

    $links   = $dom->getElementsByTagName('a');
    $broken  = [];

    foreach ($links as $a) {
        $href = $a->getAttribute('href');
        if (!$href) continue;

        $ch = curl_init($href);
        curl_setopt_array($ch, [
            CURLOPT_NOBODY         => true,
            CURLOPT_RETURNTRANSFER => true,
            CURLOPT_TIMEOUT        => 10,
            CURLOPT_FOLLOWLOCATION => true,
        ]);
        curl_exec($ch);
        $code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
        curl_close($ch);

        if ($code >= 400 || $code === 0) {
            $broken[] = $a;
        }
    }

    foreach ($broken as $a) {
        $a->parentNode->replaceChild($dom->createTextNode('[Enlace roto]'), $a);
    }

    libxml_clear_errors();
    return $dom->saveHTML();
}

/**
 * Devuelve la URL de la imagen representativa ($foto)
 * y, si procede, un enlace “clicable” relacionado ($enlace).
 *
 * - Prioridad:
 *   1) Fotos subidas por el usuario
 *   2) Vista previa local generada por scraper
 *   3) Miniatura de YouTube
 *
 * - Extensiones admitidas: jpeg|jpg|png|webp|svg|mp4
 * - Las miniaturas (prefijo m.) se generan solo para jpeg|jpg|png|webp
 *
 * @return array{string $foto, string $enlace}
 */
function getFoto($pub, array $vistas_previas): array
{
    $foto   = '';
    $enlace = '';

    $allowed = ['jpeg', 'jpg', 'png', 'webp', 'svg', 'mp4'];
    $thumb   = ['jpeg', 'jpg', 'png', 'webp'];

    /*--------------------------------------------------------------*/
    /* 1) Fotos propias                                             */
    /*--------------------------------------------------------------*/
    if (!empty($pub->fotos)) {
        $f   = strpos($pub->fotos, ',') !== false
             ? explode(',', $pub->fotos, 2)[0]
             : $pub->fotos;
        $ext = strtolower(pathinfo($f, PATHINFO_EXTENSION));

        if (in_array($ext, $allowed, true)) {
            $pref = in_array($ext, $thumb, true) ? 'm.' : '';
            $foto = DOMAIN . "img/usuarios/{$pub->usu_idu}/{$pref}{$f}";
        }
    }
    /*--------------------------------------------------------------*/
    /* 2) Vista previa local                                        */
    /*--------------------------------------------------------------*/
    elseif (!empty($vistas_previas[$pub->idu][0]->image)) {
        $vp  = $vistas_previas[$pub->idu][0];
        $f   = $vp->image;
        $ext = strtolower(pathinfo($f, PATHINFO_EXTENSION));

        if (in_array($ext, $allowed, true)) {
            $pref  = in_array($ext, $thumb, true) ? 'm.' : '';
            $foto  = DOMAIN . "img/vistas_previas/{$vp->idu}/{$pref}{$f}";
            $enlace = $vp->url;
        }
    }
    /*--------------------------------------------------------------*/
    /* 3) Miniatura de YouTube                                      */
    /*--------------------------------------------------------------*/
    elseif (!empty($pub->enlace)) {
        $enlace  = $pub->enlace;                       // se mostrará debajo
        $videoId = _var::getUrlVar($enlace);           // ya devuelve solo el ID
        if ($videoId) {
            $foto = "https://img.youtube.com/vi/{$videoId}/hqdefault.jpg";
        }
    }

    return [$foto, $enlace];
}

/**
 * Inserta el enlace de baja y el píxel de seguimiento personalizados.
 */
function replacePlaceholders(string $html, string $unsubscribe, string $email, string $boletin): string
{
    $html = str_replace(
        '<span class="baja_del_boletin"></span>',
        '<a href="' . $unsubscribe . '">QUIERO DARME DE BAJA DEL BOLETÍN Y SUCESIVAS COMUNICACIONES PASIVAS</a>',
        $html
    );

    return str_replace(
        '<span class="pixel"></span>',
        '<img alt="" src="' . DOMAIN . 'imagenes/pixel/' . base64_encode($email) . '/' . $boletin . '" width="1" height="1">',
        $html
    );
}

