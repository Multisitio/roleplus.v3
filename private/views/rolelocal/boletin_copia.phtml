/**
 * Función que reemplaza en el HTML todos los enlaces rotos por "[Enlace roto]".
 *
 * @param string $html Contenido HTML a analizar.
 * @return string HTML modificado con los enlaces rotos reemplazados.
 */
function replaceBrokenLinks($html) {
    libxml_use_internal_errors(true);
    $dom = new DOMDocument();
    // Cargamos el HTML sin forzar etiquetas html/body adicionales.
    $dom->loadHTML($html, LIBXML_HTML_NOIMPLIED | LIBXML_HTML_NODEFDTD);
    $links = $dom->getElementsByTagName('a');

    // Almacenamos los nodos a reemplazar en un array, ya que la lista es "en vivo".
    $linksToReplace = [];
    foreach ($links as $link) {
        $href = $link->getAttribute('href');
        if (!empty($href)) {
            $ch = curl_init($href);
            curl_setopt($ch, CURLOPT_NOBODY, true);
            curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
            curl_setopt($ch, CURLOPT_TIMEOUT, 10);
            curl_exec($ch);
            $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
            curl_close($ch);
            if ($httpCode >= 400 || $httpCode == 0) {
                $linksToReplace[] = $link;
            }
        }
    }
    // Reemplazamos cada enlace roto por un nodo de texto "[Enlace roto]".
    foreach ($linksToReplace as $link) {
        $textNode = $dom->createTextNode("[Enlace roto]");
        $link->parentNode->replaceChild($textNode, $link);
    }
    return $dom->saveHTML();
}

/**
 * Obtiene la URL de la imagen y el enlace asociado de la publicación.
 */
function getFoto($pub, $vistas_previas) {
    $foto = '';
    $enlace = '';
    if (!empty($pub->fotos)) {
        $foto = DOMAIN . "img/usuarios/$pub->usu_idu" .
            (preg_match('/(jpeg|jpg|png)$/', $pub->fotos) ? '/m.' : '/') .
            (strpos($pub->fotos, ',') !== false ? explode(',', $pub->fotos, 2)[0] : $pub->fotos);
    } elseif (!empty($vistas_previas[$pub->idu][0]->image)) {
        $enlace = $vistas_previas[$pub->idu][0]->url;
        $foto = DOMAIN . 'img/vistas_previas/' . $vistas_previas[$pub->idu][0]->idu .
            (preg_match('/(jpeg|jpg|png)$/', $vistas_previas[$pub->idu][0]->image) ? '/m.' : '/') .
            $vistas_previas[$pub->idu][0]->image;
    } elseif ($pub->enlace) {
        $enlace = $pub->enlace;
        $foto = 'https://i.ytimg.com/vi/' . _var::getUrlVar($pub->enlace) . '/hqdefault.jpg';
    }
    return [$foto, $enlace];
}

/**
 * Reemplaza los marcadores de baja y pixel en el contenido HTML.
 */
function replacePlaceholders($contenido, $unsubscribeUrl, $usuarioEmail, $boletin) {
    $contenido = str_replace(
        '<span class="baja_del_boletin"></span>',
        '<a href="'.$unsubscribeUrl.'">QUIERO DARME DE BAJA DEL BOLETÍN Y SUCESIVAS COMUNICACIONES PASIVAS</a>',
        $contenido
    );
    $contenido = str_replace(
        '<span class="pixel"></span>',
        '<img alt="" src="'.DOMAIN.'imagenes/pixel/'.base64_encode($usuarioEmail).'/'.$boletin.'" width="1" height="1">',
        $contenido
    );
    return $contenido;
}

